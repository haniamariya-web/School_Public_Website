<div class="max-w-4xl mx-auto">
  <h1 class="text-3xl font-bold text-navy mb-6">Edit Album</h1>

  <!-- Edit Form -->
  <%= form_with model: [:admin, @album], local: true, html: { multipart: true, class: "bg-white rounded-lg shadow-md overflow-hidden mb-8" } do |f| %>
    <div class="p-6 border-b border-gray-200">
      <h2 class="text-lg font-semibold text-navy mb-4">Album Information</h2>
      
      <div class="mb-4">
        <%= f.label :title, class: "block text-navy font-medium mb-2" %>
        <%= f.text_field :title, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-british-red" %>
      </div>

      <div class="mb-4">
        <%= f.label :description, class: "block text-navy font-medium mb-2" %>
        <%= f.text_area :description, rows: 4, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-british-red" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="mb-4">
          <%= f.label :event_date, class: "block text-navy font-medium mb-2" %>
          <%= f.date_field :event_date, class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-british-red" %>
        </div>

        <div class="mb-4">
          <%= f.label :campus_id, "Campus", class: "block text-navy font-medium mb-2" %>
          <%= f.collection_select :campus_id, Campu.all, :id, :name, { include_blank: "Select Campus" }, { class: "w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-british-red" } %>
        </div>
      </div>

      <% if @album.cover_image.attached? %>
        <div class="mb-4 p-4 bg-gray-50 rounded-lg">
          <p class="text-sm font-medium text-navy mb-2">Current Cover Image</p>
          <%= image_tag @album.cover_image, class: "max-h-32 rounded-lg" %>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :cover_image, "Replace Cover Image", class: "block text-navy font-medium mb-2" %>
        <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center hover:border-british-red transition cursor-pointer" onclick="document.getElementById('cover_image_input').click()">
          <p class="text-sm text-gray-600">Click to upload new cover image</p>
          <%= f.file_field :cover_image, accept: "image/png,image/jpeg,image/jpg", class: "hidden", id: "cover_image_input" %>
        </div>
      </div>
    </div>

    <div class="p-6 bg-gray-50 flex gap-3">
      <%= f.submit "Update Album", class: "bg-british-red text-white px-6 py-2 rounded-lg hover:bg-red-700 transition font-medium" %>
      <%= link_to "Cancel", admin_albums_path, class: "bg-gray-300 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-400 transition font-medium" %>
    </div>
  <% end %>

  <!-- Current Posts Section -->
  <div class="bg-white rounded-lg shadow-md overflow-hidden mb-8">
    <div class="p-6 border-b border-gray-200 bg-gray-50">
      <h2 class="text-lg font-semibold text-navy">Posts in This Album</h2>
      <p class="text-sm text-gray-600 mt-1"><%= @album.posts.count %> posts total</p>
    </div>
    
    <div class="divide-y divide-gray-200">
      <% if @album.posts.any? %>
        <% @album.posts.each do |post| %>
          <div class="p-4 flex justify-between items-center hover:bg-gray-50 transition">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-medium text-navy"><%= post.title %></span>
                <% if post.image.attached? %>
                  <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">📷 Image</span>
                <% end %>
                <% if post.video.attached? %>
                  <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded">🎥 Video</span>
                <% end %>
              </div>
              <p class="text-sm text-gray-500"><%= truncate(post.content, length: 80) %></p>
              <p class="text-xs text-gray-400 mt-1"><%= post.campus&.name || "All Campuses" %></p>
            </div>
            <%= button_to "Remove", remove_post_admin_album_path(@album, post_id: post.id), method: :delete, class: "text-red-600 hover:text-red-800 text-sm font-medium transition", data: { turbo_confirm: "Remove this post from album?" } %>
          </div>
        <% end %>
      <% else %>
        <div class="p-12 text-center text-gray-500">
          <p>No posts in this album yet.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Add Posts Section -->
  <div class="bg-white rounded-lg shadow-md overflow-hidden">
    <div class="p-6 border-b border-gray-200 bg-gray-50">
      <h2 class="text-lg font-semibold text-navy">Add More Posts</h2>
      <p class="text-sm text-gray-600 mt-1">Select posts to add to this album</p>
    </div>
    
    <div class="p-6">
      <% if @available_posts.any? %>
        <div class="space-y-2 max-h-96 overflow-y-auto">
          <% @available_posts.each do |post| %>
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition">
              <div class="flex-1">
                <div class="flex items-center gap-2">
                  <span class="font-medium text-navy"><%= post.title %></span>
                  <% if post.image.attached? %>
                    <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">📷 Image</span>
                  <% end %>
                  <% if post.video.attached? %>
                    <span class="text-xs bg-purple-100 text-purple-700 px-2 py-0.5 rounded">🎥 Video</span>
                  <% end %>
                </div>
                <p class="text-sm text-gray-500 mt-1"><%= truncate(post.content, length: 80) %></p>
              </div>
              <%= button_to "Add to Album", add_post_admin_album_path(@album, post_id: post.id), method: :post, class: "bg-british-red text-white px-4 py-1.5 rounded-lg hover:bg-red-700 transition text-sm font-medium" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8">
          <p class="text-gray-500 mb-4">No more posts available to add.</p>
          <%= link_to "Create New Post", new_admin_post_path, class: "bg-british-red text-white px-4 py-2 rounded-lg hover:bg-red-700 transition inline-block" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
