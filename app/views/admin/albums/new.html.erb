<div class="max-w-4xl mx-auto px-4">
  <h1 class="text-3xl font-bold text-navy mb-2">Create New Album</h1>
  <div class="w-16 h-px bg-british-red mb-6"></div>

  <%= form_with model: [:admin, @album], local: true, html: { multipart: true, class: "space-y-6" } do |f| %>
    <% if @album.errors.any? %>
      <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-lg">
        <div class="flex">
          <svg class="h-5 w-5 text-red-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= pluralize(@album.errors.count, "error") %> prohibited this album from being saved:</h3>
            <ul class="mt-1 text-sm text-red-700 list-disc list-inside">
              <% @album.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Album Information Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <h2 class="text-lg font-semibold text-navy">Album Information</h2>
      </div>
      
      <div class="p-6 space-y-5">
        <div>
          <%= f.label :title, class: "block text-navy font-medium mb-1.5" %>
          <%= f.text_field :title, class: "w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-british-red focus:border-transparent transition", placeholder: "e.g., Annual Sports Day 2025" %>
        </div>

        <div>
          <%= f.label :description, class: "block text-navy font-medium mb-1.5" %>
          <%= f.text_area :description, rows: 4, class: "w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-british-red focus:border-transparent transition", placeholder: "Describe this event..." %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div>
            <%= f.label :event_date, class: "block text-navy font-medium mb-1.5" %>
            <%= f.date_field :event_date, class: "w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-british-red focus:border-transparent transition" %>
          </div>

          <div>
            <%= f.label :campus_id, "Campus", class: "block text-navy font-medium mb-1.5" %>
            <%= f.collection_select :campus_id, Campu.all, :id, :name, { include_blank: "Select Campus" }, { class: "w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-british-red focus:border-transparent transition" } %>
          </div>
        </div>

        <div>
          <%= f.label :cover_image, "Cover Image", class: "block text-navy font-medium mb-1.5" %>
          <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-lg hover:border-british-red transition cursor-pointer" onclick="document.getElementById('cover_image_input').click()">
            <div class="space-y-1 text-center">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
              <div class="flex text-sm text-gray-600">
                <span class="relative font-medium text-british-red hover:text-red-700">Upload a cover image</span>
              </div>
              <p class="text-xs text-gray-500">PNG, JPG, JPEG up to 5MB</p>
              <%= f.file_field :cover_image, accept: "image/png,image/jpeg,image/jpg", class: "hidden", id: "cover_image_input" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Post Selection Card - Simple Native Multiple Select -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
      <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
        <h2 class="text-lg font-semibold text-navy">Select Posts</h2>
        <p class="text-sm text-gray-600 mt-0.5">Choose posts to include in this album</p>
      </div>
      
      <div class="p-6">
        <% if @available_posts.any? %>
          <div class="relative">
            <select name="album[post_ids][]" multiple 
                    class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-british-red focus:border-transparent transition min-h-[200px]">
              <% @available_posts.each do |post| %>
                <option value="<%= post.id %>" class="py-1">
                  <%= post.title %>
                  <% if post.image.attached? %> 📷<% end %>
                  <% if post.video.attached? %> 🎥<% end %>
                  (<%= post.campus&.name || "All Campuses" %>)
                </option>
              <% end %>
            </select>
          </div>
          <div class="mt-3 flex gap-4 text-xs text-gray-500">
            <span>📌 Hold <kbd class="px-2 py-0.5 bg-gray-100 rounded">Ctrl</kbd> (Windows) or <kbd class="px-2 py-0.5 bg-gray-100 rounded">Cmd</kbd> (Mac) to select multiple</span>
            <span>📌 Shift + Click to select range</span>
          </div>
        <% else %>
          <div class="text-center py-8">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
            <p class="text-gray-500 mt-2 mb-4">No posts available</p>
            <%= link_to "Create Your First Post", new_admin_post_path, class: "bg-british-red text-white px-4 py-2 rounded-lg hover:bg-red-700 transition inline-block" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Form Actions -->
    <div class="flex gap-3 justify-end">
      <%= link_to "Cancel", admin_albums_path, class: "px-6 py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition font-medium" %>
      <%= f.submit "Create Album", class: "bg-british-red text-white px-6 py-2.5 rounded-lg hover:bg-red-700 transition font-medium" %>
    </div>
  <% end %>
</div>
