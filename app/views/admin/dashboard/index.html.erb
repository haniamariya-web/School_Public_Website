<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-light text-navy mb-2" style="font-family: 'Playfair Display', serif;">Dashboard</h1>
    <div class="w-16 h-px bg-british-red"></div>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <!-- Posts Card -->
    <div class="bg-white rounded-sm shadow-md hover:shadow-lg transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="bg-british-red/10 p-3 rounded-full">
            <svg class="w-6 h-6 text-british-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
            </svg>
          </div>
          <span class="text-3xl font-bold text-navy"><%= @posts_count %></span>
        </div>
        <h3 class="text-lg font-semibold text-navy mb-1">Total Posts</h3>
        <p class="text-gray-500 text-sm">News & announcements</p>
        <%= link_to admin_posts_path, class: "inline-block mt-4 text-british-red hover:text-red-700 text-sm font-semibold transition" do %>
          Manage Posts →
        <% end %>
      </div>
    </div>

    <!-- Campuses Card -->
    <div class="bg-white rounded-sm shadow-md hover:shadow-lg transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="bg-british-red/10 p-3 rounded-full">
            <svg class="w-6 h-6 text-british-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <span class="text-3xl font-bold text-navy"><%= @campuses_count %></span>
        </div>
        <h3 class="text-lg font-semibold text-navy mb-1">Campuses</h3>
        <p class="text-gray-500 text-sm">Nationwide locations</p>
        <%= link_to admin_campu_index_path, class: "inline-block mt-4 text-british-red hover:text-red-700 text-sm font-semibold transition" do %>
          Manage Campuses →
        <% end %>
      </div>
    </div>

    <!-- Inquiries Card -->
    <div class="bg-white rounded-sm shadow-md hover:shadow-lg transition-shadow duration-300">
      <div class="p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="bg-british-red/10 p-3 rounded-full">
            <svg class="w-6 h-6 text-british-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <span class="text-3xl font-bold text-navy"><%= @inquiries_count %></span>
        </div>
        <h3 class="text-lg font-semibold text-navy mb-1">Pending Inquiries</h3>
        <p class="text-gray-500 text-sm">Need your attention</p>
        <%= link_to admin_inquiries_path, class: "inline-block mt-4 text-british-red hover:text-red-700 text-sm font-semibold transition" do %>
          View Inquiries →
        <% end %>
      </div>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="bg-white rounded-sm shadow-md p-6">
    <h2 class="text-xl font-light text-navy mb-4" style="font-family: 'Playfair Display', serif;">Quick Actions</h2>
    <div class="w-16 h-px bg-british-red mb-6"></div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <%= link_to new_admin_post_path, class: "bg-navy text-white px-4 py-3 rounded-sm hover:bg-opacity-90 transition text-center text-sm font-semibold tracking-wide" do %>
        + Create New Post
      <% end %>
      <%= link_to new_admin_campu_path, class: "bg-navy text-white px-4 py-3 rounded-sm hover:bg-opacity-90 transition text-center text-sm font-semibold tracking-wide" do %>
        + Add New Campus
      <% end %>
      <%= link_to admin_inquiries_path, class: "bg-british-red text-white px-4 py-3 rounded-sm hover:bg-red-700 transition text-center text-sm font-semibold tracking-wide" do %>
        📋 Review Inquiries
      <% end %>
    </div>
  </div>
</div>
