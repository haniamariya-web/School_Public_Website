<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-4xl font-light text-navy mb-2" style="font-family: 'Playfair Display', serif;">Dashboard</h1>
      <p class="text-gray-600">Welcome back! Here's what's happening with your content.</p>
     
    </div>

    <!-- Primary Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
      <!-- Posts Card -->
      <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 border-t-4 border-british-red">
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="bg-british-red/10 p-3 rounded-full">
              <svg class="w-6 h-6 text-british-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path>
              </svg>
            </div>
            <span class="text-3xl font-bold text-navy"><%= @posts_count %></span>
          </div>
          <h3 class="text-sm font-semibold text-gray-700 mb-1">Total Posts</h3>
          <p class="text-gray-500 text-xs mb-4">Announcements & updates</p>
          <%= link_to new_admin_post_path, class: "inline-flex items-center text-british-red hover:text-red-700 text-xs font-semibold transition" do %>
            <span>New Post</span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          <% end %>
        </div>
      </div>

      <!-- News Card -->
      <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 border-t-4 border-navy">
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="bg-navy/10 p-3 rounded-full">
              <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2"></path>
              </svg>
            </div>
            <span class="text-3xl font-bold text-navy"><%= @news_count %></span>
          </div>
          <h3 class="text-sm font-semibold text-gray-700 mb-1">News Articles</h3>
          <p class="text-gray-500 text-xs mb-4">Published content</p>
          <%= link_to new_admin_news_path, class: "inline-flex items-center text-navy hover:text-navy/80 text-xs font-semibold transition" do %>
            <span>Add News</span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          <% end %>
        </div>
      </div>

      <!-- Campuses Card -->
      <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 border-t-4 border-green-600">
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="bg-green-600/10 p-3 rounded-full">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <span class="text-3xl font-bold text-navy"><%= @campuses_count %></span>
          </div>
          <h3 class="text-sm font-semibold text-gray-700 mb-1">Campuses</h3>
          <p class="text-gray-500 text-xs mb-4">Locations managed</p>
          <%= link_to new_admin_campu_path, class: "inline-flex items-center text-green-600 hover:text-green-700 text-xs font-semibold transition" do %>
            <span>New Campus</span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          <% end %>
        </div>
      </div>

      <!-- Albums Card -->
      <div class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 border-t-4 border-purple-600">
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <div class="bg-purple-600/10 p-3 rounded-full">
              <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
            <span class="text-3xl font-bold text-navy"><%= @albums_count %></span>
          </div>
          <h3 class="text-sm font-semibold text-gray-700 mb-1">Albums</h3>
          <p class="text-gray-500 text-xs mb-4">Photo galleries</p>
          <%= link_to new_admin_album_path, class: "inline-flex items-center text-purple-600 hover:text-purple-700 text-xs font-semibold transition" do %>
            <span>New Album</span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Secondary Stats & Inquiries -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
      <!-- Inquiries Overview -->
      <div class="lg:col-span-1 bg-white rounded-lg shadow-sm border-l-4 border-british-red">
        <div class="p-6">
          <h3 class="text-lg font-semibold text-navy mb-6" style="font-family: 'Playfair Display', serif;">Contact Inquiries</h3>
          <div class="space-y-4">
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-700">Pending</span>
                <span class="text-2xl font-bold text-british-red"><%= @inquiries_count %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <% contacted_percentage = @total_contacts > 0 ? ((@contacted_count.to_f / @total_contacts) * 100).to_i : 0 %>
                <div class="bg-british-red h-2 rounded-full" style="width: <%= 100 - contacted_percentage %>%"></div>
              </div>
            </div>
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-gray-700">Contacted</span>
                <span class="text-2xl font-bold text-green-600"><%= @contacted_count %></span>
              </div>
              <div class="w-full bg-gray-200 rounded-full h-2">
                <div class="bg-green-600 h-2 rounded-full" style="width: <%= contacted_percentage %>%"></div>
              </div>
            </div>
            <div class="pt-4 border-t">
              <p class="text-xs text-gray-500 mb-3">Total: <%= @total_contacts %> inquiries</p>
              <%= link_to admin_inquiries_path, class: "block w-full bg-british-red text-white text-center py-2 rounded hover:bg-red-700 transition text-sm font-semibold" do %>
                View All Inquiries
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Posts -->
      <div class="lg:col-span-2 bg-white rounded-lg shadow-sm">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-semibold text-navy" style="font-family: 'Playfair Display', serif;">Recent Posts</h3>
            <%= link_to admin_posts_path, class: "text-british-red hover:text-red-700 text-sm font-semibold" do %>
              View All →
            <% end %>
          </div>
          <div class="space-y-4">
            <% if @recent_posts.any? %>
              <% @recent_posts.each do |post| %>
                <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                  <div class="flex-1 min-w-0">
                    <p class="font-medium text-gray-900 truncate"><%= post.title %></p>
                    <p class="text-xs text-gray-500 mt-1">
                      <% if post.campus %>
                        Campus: <%= post.campus.name %>
                      <% else %>
                        All Campuses
                      <% end %>
                    </p>
                  </div>
                  <div class="ml-4 text-right">
                    <p class="text-xs text-gray-500"><%= post.created_at.strftime("%b %d") %></p>
                    <%= link_to edit_admin_post_path(post), class: "text-british-red hover:text-red-700 text-xs font-semibold mt-1 inline-block" do %>
                      Edit →
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p class="text-center text-gray-500 text-sm py-4">No posts yet</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- News & Recent Inquiries -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">
      <!-- Recent News -->
      <div class="bg-white rounded-lg shadow-sm">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-semibold text-navy" style="font-family: 'Playfair Display', serif;">Recent News</h3>
            <%= link_to admin_news_index_path, class: "text-navy hover:text-navy/80 text-sm font-semibold" do %>
              View All →
            <% end %>
          </div>
          <div class="space-y-4">
            <% if @recent_news.any? %>
              <% @recent_news.each do |news| %>
                <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                  <div class="flex-1 min-w-0">
                    <p class="font-medium text-gray-900 truncate"><%= news.title %></p>
                    <p class="text-xs text-gray-500 mt-1">
                      <% if news.published_at %>
                        <%= news.published_at.strftime("%b %d, %Y") %>
                      <% else %>
                        Draft
                      <% end %>
                    </p>
                  </div>
                  <div class="ml-4 text-right">
                    <%= link_to edit_admin_news_path(news), class: "text-navy hover:text-navy/80 text-xs font-semibold inline-block" do %>
                      Edit →
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p class="text-center text-gray-500 text-sm py-4">No news articles yet</p>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Recent Inquiries -->
      <div class="bg-white rounded-lg shadow-sm">
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-semibold text-navy" style="font-family: 'Playfair Display', serif;">Pending Inquiries</h3>
            <% if @inquiries_count > 0 %>
              <span class="bg-british-red/10 text-british-red text-xs font-semibold px-3 py-1 rounded-full">
                <%= @inquiries_count %>
              </span>
            <% end %>
          </div>
          <div class="space-y-4">
            <% if @recent_inquiries.any? %>
              <% @recent_inquiries.each do |inquiry| %>
                <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                  <div class="flex-1 min-w-0">
                    <p class="font-medium text-gray-900"><%= inquiry.name %></p>
                    <p class="text-xs text-gray-500 mt-1"><%= inquiry.email %></p>
                    <p class="text-xs text-gray-500">Grade: <%= inquiry.grade_level %></p>
                  </div>
                  <div class="ml-4 text-right">
                    <p class="text-xs text-gray-500 mb-2"><%= inquiry.created_at.strftime("%b %d") %></p>
                    <%= button_to mark_contacted_admin_inquiry_path(inquiry), method: :patch, class: "bg-british-red text-white text-xs font-semibold px-3 py-1 rounded hover:bg-red-700 transition" do %>
                      Contacted
                    <% end %>
                  </div>
                </div>
              <% end %>
            <% else %>
              <p class="text-center text-gray-500 text-sm py-4">No pending inquiries</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="bg-gradient-to-r from-navy to-navy/80 rounded-lg shadow-lg p-8 text-white">
      <h2 class="text-2xl font-light mb-2" style="font-family: 'Playfair Display', serif;">Quick Actions</h2>
      <p class="text-navy-100 text-sm mb-6">Manage your content quickly from here</p>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        <%= link_to new_admin_post_path, class: "bg-white/20 hover:bg-white/30 text-white px-4 py-3 rounded-lg transition text-center text-sm font-semibold" do %>
          📝 New Post
        <% end %>
        <%= link_to new_admin_news_path, class: "bg-white/20 hover:bg-white/30 text-white px-4 py-3 rounded-lg transition text-center text-sm font-semibold" do %>
          📰 New Article
        <% end %>
        <%= link_to new_admin_campu_path, class: "bg-white/20 hover:bg-white/30 text-white px-4 py-3 rounded-lg transition text-center text-sm font-semibold" do %>
          🏢 New Campus
        <% end %>
        <%= link_to new_admin_album_path, class: "bg-white/20 hover:bg-white/30 text-white px-4 py-3 rounded-lg transition text-center text-sm font-semibold" do %>
          🖼️ New Album
        <% end %>
        <%= link_to admin_inquiries_path, class: "bg-british-red hover:bg-red-700 text-white px-4 py-3 rounded-lg transition text-center text-sm font-semibold" do %>
          💬 Inquiries
        <% end %>
      </div>
    </div>
  </div>
</div>
