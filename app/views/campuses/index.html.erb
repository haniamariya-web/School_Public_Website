<div class="min-h-screen bg-gray-50" data-controller="campuses">
  <!-- Hero Section -->
  <section class="relative h-[300px] md:h-[400px] flex items-center justify-center bg-navy overflow-hidden">
    <div class="absolute inset-0 opacity-20 bg-[url('https://images.unsplash.com/photo-1541339907198-e08756dedf3f?w=1600')] bg-cover bg-center"></div>
    <div class="relative text-center px-4 reveal opacity-0 translate-y-10 transition duration-1000">
      <h1 class="text-4xl md:text-6xl font-light text-white mb-4 tracking-tight font-playfair">Our Campuses</h1>
      <div class="w-20 h-1 bg-british-red mx-auto mb-6"></div>
      <p class="text-gray-300 max-w-2xl mx-auto text-sm md:text-base font-light tracking-wide">
        Explore our expanding network of educational excellence across multiple regions.
      </p>
    </div>
  </section>

  <!-- Main Content Layout -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 flex flex-col md:flex-row gap-12 relative items-start">
    
    <!-- Sticky Sidebar Navigation -->
    <aside class="md:w-1/4 hidden md:block sticky top-24">
      <div class="bg-white p-6 shadow-sm border-t-4 border-navy rounded-sm">
        <h3 class="text-lg font-semibold text-navy mb-6 font-playfair italic">Categories</h3>
        <nav class="space-y-2 flex flex-col">
          <% @categories.each_with_index do |(key, data), index| %>
            <a href="#<%= key %>" 
               data-campuses-target="navLink"
               data-action="click->campuses#scrollToSection"
               class="px-4 py-3 text-sm font-medium transition-colors duration-300 border-l-2 <%= index == 0 ? 'border-british-red text-british-red bg-red-50/50' : 'border-transparent text-gray-500 hover:text-navy hover:bg-gray-50' %>">
              <%= data[:title] %>
            </a>
          <% end %>
        </nav>
      </div>
    </aside>

    <!-- Mobile Navigation (Horizontal Scroll) -->
    <div class="md:hidden w-full overflow-x-auto pb-4 -mx-4 px-4 sticky top-16 bg-gray-50/95 backdrop-blur z-40 border-b border-gray-200">
      <nav class="flex space-x-4 min-w-max pt-4">
        <% @categories.each_with_index do |(key, data), index| %>
          <a href="#<%= key %>" 
             data-campuses-target="mobileNavLink"
             data-action="click->campuses#scrollToSection"
             class="px-4 py-2 text-sm font-medium whitespace-nowrap rounded-full transition-colors duration-300 border <%= index == 0 ? 'border-british-red bg-british-red text-white' : 'border-gray-200 bg-white text-gray-600' %>">
            <%= data[:title] %>
          </a>
        <% end %>
      </nav>
    </div>

    <!-- Campuses Sections -->
    <div class="md:w-3/4 space-y-24">
      <% @categories.each do |key, data| %>
        <section id="<%= key %>" data-campuses-target="section" class="scroll-mt-32">
          <div class="mb-8 border-b border-gray-200 pb-4 reveal opacity-0 translate-y-10 transition duration-1000">
            <h2 class="text-3xl font-light text-navy font-playfair"><%= data[:title] %></h2>
            <p class="text-sm text-gray-500 mt-2"><%= data[:campuses].size %> Campuses</p>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <% data[:campuses].each do |campus| %>
              <div class="bg-white group rounded-sm shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden border border-gray-100 reveal opacity-0 translate-y-10 transition duration-1000">
                <div class="h-2 w-full bg-navy group-hover:bg-british-red transition-colors duration-300"></div>
                <div class="p-6">
                  <h3 class="text-xl font-semibold text-navy mb-2 group-hover:text-british-red transition-colors"><%= campus.name %></h3>
                  <div class="space-y-3 mt-4 text-sm text-gray-600">
                    <% if campus.address.present? %>
                      <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        <span><%= campus.address %></span>
                      </div>
                    <% end %>
                    
                    <% if campus.phone.present? %>
                      <div class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                        <span><%= campus.phone %></span>
                      </div>
                    <% end %>
                    
                    <% if campus.email.present? %>
                      <div class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        <a href="mailto:<%= campus.email %>" class="hover:text-british-red transition"><%= campus.email %></a>
                      </div>
                    <% end %>
                    
                    <% if campus.principal_name.present? %>
                      <div class="pt-4 mt-4 border-t border-gray-100 flex items-center justify-between">
                        <span class="text-xs font-semibold tracking-widest uppercase text-gray-400">Principal</span>
                        <span class="font-medium text-navy"><%= campus.principal_name %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>
    </div>
  </div>
</div>
