<div class="min-h-screen bg-gray-50" data-controller="campuses">
  <!-- Hero Section -->
  <section class="relative h-[300px] md:h-[400px] flex items-center justify-center bg-navy overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy to-[#001530]"></div>
    
    <!-- Decorative elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden opacity-10 pointer-events-none">
      <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full border-[1px] border-white/20"></div>
      <div class="absolute top-1/2 right-12 w-64 h-64 rounded-full border-[1px] border-white/20"></div>
    </div>

    <div class="relative text-center px-4 reveal opacity-0 translate-y-10 transition duration-1000">
      <p class="text-xs tracking-widest text-british-red mb-4 uppercase font-semibold">Gallery</p>
      <h1 class="text-4xl md:text-6xl font-light text-white mb-4 tracking-tight font-playfair">Moments That Matter</h1>
      <div class="w-20 h-1 bg-british-red mx-auto mb-6"></div>
      <p class="text-gray-300 max-w-2xl mx-auto text-sm md:text-base font-light tracking-wide">
        A glimpse into events, achievements, and everyday life across our campuses
      </p>
    </div>
  </section>

  <!-- Main Content Layout -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-24">

    <!-- Albums Grid -->
    <section>
      <div class="mb-10 text-center reveal opacity-0 translate-y-10 transition duration-1000">
        <h2 class="text-3xl font-light text-navy font-playfair">Our Albums</h2>
        <p class="text-sm text-gray-500 mt-2">Browse through collections of our cherished memories</p>
      </div>

      <% if @albums.any? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          <% @albums.each_with_index do |album, index| %>
            <%= link_to gallery_album_path(album), class: "group block reveal opacity-0 translate-y-10 transition duration-1000", style: "transition-delay: #{index * 100}ms;" do %>
              <div class="bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-gray-100 h-full flex flex-col">
                
                <div class="relative aspect-[4/3] w-full overflow-hidden bg-gray-100">
                  <div class="absolute inset-0 bg-navy/20 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
                  <% if (img = gallery_image(album)).present? %>
                    <%= image_tag img, class: "w-full h-full object-cover transform group-hover:scale-110 transition duration-700 ease-out" %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-gray-400">
                      <svg class="w-12 h-12 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                  <% end %>
                  
                  <!-- Album badge -->
                  <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-navy text-xs font-semibold px-2 py-1 rounded shadow-sm z-20">
                    <%= album.posts.count %> Photos
                  </div>
                </div>
            
                <div class="p-5 flex-grow flex flex-col justify-between">
                  <div>
                    <h3 class="text-lg font-semibold text-navy line-clamp-2 group-hover:text-british-red transition-colors duration-300">
                      <%= album.title %>
                    </h3>
                  </div>
                  
                  <div class="mt-4 pt-4 border-t border-gray-100 space-y-1">
                    <p class="text-xs text-gray-500 flex items-center gap-1.5">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                      <%= album.event_date&.strftime("%B %d, %Y") || "Upcoming" %>
                    </p>
                    <p class="text-xs text-gray-400 flex items-center gap-1.5 line-clamp-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                      <%= album.campus&.name || "All Campuses" %>
                    </p>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white border rounded-sm p-16 text-center text-gray-500 shadow-sm reveal opacity-0 translate-y-10 transition duration-1000">
          <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          <p class="text-lg">No albums available yet.</p>
        </div>
      <% end %>
    </section>

    <!-- Latest Posts Strip -->
    <% if @posts.any? %>
      <section class="bg-white rounded-sm shadow-sm border border-gray-100 p-8 reveal opacity-0 translate-y-10 transition duration-1000">
        <div class="flex justify-between items-center mb-8 border-b border-gray-100 pb-4">
          <div>
            <h2 class="text-2xl font-light text-navy font-playfair">Latest Moments</h2>
            <p class="text-xs text-gray-500 mt-1 uppercase tracking-wider">Recent Posts from all Campuses</p>
          </div>
          
          <!-- Carousel Navigation -->
          <div class="flex gap-2" data-controller="scroll-carousel">
            <button data-action="click->scroll-carousel#prev" class="p-2 border border-gray-200 rounded-full hover:border-british-red hover:text-british-red hover:bg-red-50 transition duration-300 text-gray-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button data-action="click->scroll-carousel#next" class="p-2 border border-gray-200 rounded-full hover:border-british-red hover:text-british-red hover:bg-red-50 transition duration-300 text-gray-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <div data-scroll-carousel-target="container" class="flex gap-6 overflow-x-auto scroll-smooth pb-4 snap-x snap-mandatory scrollbar-hide">
          <% @posts.each do |post| %>
            <div class="group flex-shrink-0 w-[280px] snap-start relative overflow-hidden rounded-sm bg-gray-100 aspect-square">
              <% if post.image.attached? %>
                <%= image_tag post.image, class: "w-full h-full object-cover transform group-hover:scale-110 transition duration-700" %>
              <% elsif post.video.attached? %>
                <video class="w-full h-full object-cover transform group-hover:scale-110 transition duration-700" muted loop playsinline onmouseover="this.play()" onmouseout="this.pause()">
                  <source src="<%= url_for(post.video) %>">
                </video>
              <% end %>
              
              <!-- Post Overlay Details -->
              <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-5">
                <h4 class="text-white font-medium line-clamp-2 text-sm leading-tight mb-2"><%= post.title %></h4>
                <div class="flex justify-between items-end text-xs text-gray-300 border-t border-white/20 pt-2 mt-auto">
                  <span class="truncate pr-2"><%= post.campus&.name || "BIS" %></span>
                  <span class="flex-shrink-0"><%= post.created_at.strftime("%b %d") %></span>
                </div>
              </div>
              
              <!-- Media Icon Badge -->
              <div class="absolute top-3 left-3 bg-black/50 backdrop-blur-sm rounded-full p-1.5 opacity-100 group-hover:opacity-0 transition-opacity duration-300">
                <% if post.image.attached? %>
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <% else %>
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>

  </div>
</div>

<style>
  /* Hide scrollbar for the latest posts strip but keep functionality */
  .scrollbar-hide::-webkit-scrollbar {
      display: none;
  }
  .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
  }
</style>