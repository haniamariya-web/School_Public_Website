<div class="min-h-screen bg-gradient-to-b from-gray-50 to-white">
  <!-- Hero Section -->
  <div class="relative bg-navy overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0 bg-gradient-to-r from-british-red to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <%= link_to gallery_path, class: "inline-flex items-center gap-2 text-gray-300 hover:text-white transition mb-6 group" do %>
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Gallery
      <% end %>
      
      <div class="text-center">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-light text-white mb-4 tracking-tight" style="font-family: 'Playfair Display', serif;"><%= @album.title %></h1>
        <div class="w-20 h-px bg-british-red mx-auto mb-6"></div>
        <div class="flex justify-center gap-6 text-gray-300 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span><%= @album.event_date&.strftime("%B %d, %Y") || "Date TBD" %></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            <span><%= @album.campus&.name || "All Campuses" %></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
            <span><%= @album.posts.count %> moments</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Album Description -->
  <% if @album.description.present? %>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="bg-white rounded-xl shadow-sm p-8 text-center">
        <p class="text-gray-700 text-lg leading-relaxed"><%= @album.description %></p>
      </div>
    </div>
  <% end %>

  <!-- Posts Grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <% if @album.posts.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @album.posts.each do |post| %>
          <div class="group bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
            <!-- Media -->
            <div class="relative h-72 overflow-hidden bg-gray-200">
              <% if post.image.attached? %>
                <%= image_tag post.image, class: "w-full h-full object-cover group-hover:scale-105 transition duration-500" %>
              <% elsif post.video.attached? %>
                <video class="w-full h-full object-cover group-hover:scale-105 transition duration-500" controls>
                  <source src="<%= url_for(post.video) %>">
                </video>
              <% else %>
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-100 to-gray-200">
                  <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
              <% end %>
              
              <!-- Type Badge -->
              <div class="absolute top-3 left-3 bg-black/50 backdrop-blur-sm rounded-full p-1.5">
                <% if post.image.attached? %>
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                <% elsif post.video.attached? %>
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                  </svg>
                <% end %>
              </div>
            </div>
            
            <!-- Content -->
            <div class="p-5">
              <h3 class="text-lg font-semibold text-navy mb-2"><%= post.title %></h3>
              <p class="text-gray-600 text-sm leading-relaxed"><%= post.content %></p>
              <div class="mt-3 flex items-center justify-between">
                <span class="text-xs text-gray-400"><%= post.created_at.strftime("%B %d, %Y") %></span>
                <% if post.campus %>
                  <span class="text-xs text-gray-400"><%= post.campus.name %></span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 bg-white rounded-xl shadow-sm">
        <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <p class="text-gray-500">No posts in this album yet.</p>
      </div>
    <% end %>
  </div>
</div>
