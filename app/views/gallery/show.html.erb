<div class="min-h-screen bg-gray-50" data-controller="campuses">
  <!-- Hero Section -->
  <section class="relative h-[300px] md:h-[400px] flex items-center justify-center bg-navy overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy to-[#001530]"></div>
    
    <!-- Decorative elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden opacity-10 pointer-events-none">
      <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full border-[1px] border-white/20"></div>
      <div class="absolute top-1/2 right-12 w-64 h-64 rounded-full border-[1px] border-white/20"></div>
    </div>

    <div class="relative text-center px-4 max-w-4xl mx-auto reveal opacity-0 translate-y-10 transition duration-1000">
      <%= link_to gallery_path, class: "inline-flex items-center gap-2 text-gray-400 hover:text-british-red transition mb-6 group text-sm font-semibold tracking-wider uppercase" do %>
        <svg class="w-4 h-4 group-hover:-translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Gallery
      <% end %>

      <h1 class="text-4xl md:text-6xl font-light text-white mb-4 tracking-tight font-playfair"><%= @album.title %></h1>
      <div class="w-20 h-1 bg-british-red mx-auto mb-8"></div>
      
      <div class="flex flex-wrap justify-center gap-6 md:gap-10 text-gray-300 text-sm font-light tracking-wide">
        <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-full border border-white/10 backdrop-blur-sm">
          <svg class="w-4 h-4 text-british-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span><%= @album.event_date&.strftime("%B %d, %Y") || "Date TBD" %></span>
        </div>
        <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-full border border-white/10 backdrop-blur-sm">
          <svg class="w-4 h-4 text-british-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
          </svg>
          <span><%= @album.campus&.name || "All Campuses" %></span>
        </div>
        <div class="flex items-center gap-2 bg-white/5 px-4 py-2 rounded-full border border-white/10 backdrop-blur-sm">
          <svg class="w-4 h-4 text-british-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          <span><%= @album.posts.count %> Moments</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content Layout -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    
    <!-- Album Description -->
    <% if @album.description.present? %>
      <div class="max-w-4xl mx-auto mb-16 reveal opacity-0 translate-y-10 transition duration-1000">
        <div class="bg-white rounded-sm shadow-sm border border-gray-100 p-8 md:p-12 text-center relative">
          <!-- Quote icon decorative -->
          <svg class="w-10 h-10 text-gray-100 absolute top-4 left-4" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <p class="text-gray-600 text-lg md:text-xl font-light leading-relaxed italic relative z-10 font-playfair"><%= @album.description %></p>
        </div>
      </div>
    <% end %>

    <!-- Posts Grid -->
    <% if @album.posts.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <% @album.posts.each_with_index do |post, index| %>
          <div class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 reveal opacity-0 translate-y-10 transition duration-1000 flex flex-col h-full" style="transition-delay: <%= index % 4 * 100 %>ms;">
            
            <!-- Media -->
            <div class="relative aspect-[4/3] overflow-hidden bg-gray-100 flex-shrink-0">
              <% if post.image.attached? %>
                <%= image_tag post.image, class: "w-full h-full object-cover transform group-hover:scale-105 transition duration-700 ease-out" %>
              <% elsif post.video.attached? %>
                <video class="w-full h-full object-cover transform group-hover:scale-105 transition duration-700 ease-out" controls>
                  <source src="<%= url_for(post.video) %>">
                </video>
              <% else %>
                <div class="w-full h-full flex items-center justify-center bg-gray-50">
                  <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
              <% end %>
              
              <!-- Type Badge -->
              <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm rounded shadow-sm px-2 py-1 flex items-center gap-1">
                <% if post.image.attached? %>
                  <svg class="w-3 h-3 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  <span class="text-[10px] font-semibold text-navy uppercase tracking-wider">Photo</span>
                <% elsif post.video.attached? %>
                  <svg class="w-3 h-3 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                  <span class="text-[10px] font-semibold text-navy uppercase tracking-wider">Video</span>
                <% end %>
              </div>
            </div>
            
            <!-- Content -->
            <div class="p-5 flex-grow flex flex-col justify-between border-t border-gray-100">
              <div>
                <h3 class="text-lg font-semibold text-navy mb-2 group-hover:text-british-red transition-colors duration-300"><%= post.title %></h3>
                <p class="text-gray-600 text-sm leading-relaxed mb-4 line-clamp-3"><%= post.content %></p>
              </div>
              <div class="pt-4 flex items-center justify-between border-t border-gray-50 text-xs font-medium text-gray-400">
                <span class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg><%= post.created_at.strftime("%b %d, %Y") %></span>
                <% if post.campus %>
                  <span class="bg-gray-100 text-gray-500 px-2 py-1 rounded truncate max-w-[120px]"><%= post.campus.name %></span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20 bg-white rounded-sm border border-gray-100 shadow-sm reveal opacity-0 translate-y-10 transition duration-1000">
        <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <h3 class="text-xl font-medium text-navy mb-2">No moments to show</h3>
        <p class="text-gray-500 max-w-md mx-auto">This album is currently empty. Check back later for new photos and videos.</p>
      </div>
    <% end %>
  </div>
</div>
