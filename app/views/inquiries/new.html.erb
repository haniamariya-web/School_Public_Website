<div class="min-h-screen bg-white">


  <!-- Hero Section -->
  <div class="relative h-[300px] bg-cover bg-center" style="background-image: linear-gradient(rgba(0,33,71,0.7), rgba(0,33,71,0.7)), url('https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=1600');">
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="text-center text-white">
        <h1 class="text-5xl md:text-6xl font-light mb-4 tracking-tight" style="font-family: 'Playfair Display', serif;">Begin Your Journey</h1>
        <div class="w-16 h-px bg-british-red mx-auto"></div>
        <p class="mt-6 text-lg font-light">Join the BIS family today</p>
      </div>
    </div>
  </div>

  <!-- Form Section -->
  <div class="py-20 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Form Card -->
      <div class="bg-white shadow-xl rounded-sm overflow-hidden">
        <div class="bg-navy px-8 py-6">
          <h2 class="text-2xl font-light text-white tracking-tight" style="font-family: 'Playfair Display', serif;">Admissions Inquiry</h2>
          <p class="text-gray-300 text-sm mt-1">Fill out the form below and our admissions team will contact you</p>
        </div>
        
        <%= form_with model: @inquiry, local: true, class: "p-8" do |f| %>
          <% if @inquiry.errors.any? %>
            <div class="bg-red-50 border-l-4 border-british-red p-4 mb-6">
              <p class="text-red-700 text-sm"><%= pluralize(@inquiry.errors.count, "error") %> prohibited this inquiry:</p>
              <ul class="list-disc list-inside text-red-600 text-sm mt-2">
                <% @inquiry.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <%= f.label :name, "Full Name", class: "block text-navy text-sm font-semibold mb-2" %>
              <%= f.text_field :name, required: true, class: "w-full px-4 py-3 border border-gray-300 rounded-sm focus:outline-none focus:border-british-red transition", placeholder: "Enter your full name" %>
            </div>
            
            <div>
              <%= f.label :email, "Email Address", class: "block text-navy text-sm font-semibold mb-2" %>
              <%= f.email_field :email, required: true, class: "w-full px-4 py-3 border border-gray-300 rounded-sm focus:outline-none focus:border-british-red transition", placeholder: "you@example.com" %>
            </div>
            
            <div>
              <%= f.label :phone, "Phone Number", class: "block text-navy text-sm font-semibold mb-2" %>
              <%= f.telephone_field :phone, required: true, class: "w-full px-4 py-3 border border-gray-300 rounded-sm focus:outline-none focus:border-british-red transition", placeholder: "0300 1234567" %>
            </div>
            
            <div>
              <%= f.label :grade_level, "Grade Applying For", class: "block text-navy text-sm font-semibold mb-2" %>
              <%= f.select :grade_level, options_for_select(["Play Group", "Nursery", "Prep", "1", "2", "3", "4", "5", "6", "7", "8", "9 (Matric)", "10 (Matric)", "Hifz Program"]), { prompt: "Select grade" }, { required: true, class: "w-full px-4 py-3 border border-gray-300 rounded-sm focus:outline-none focus:border-british-red transition bg-white" } %>
            </div>
          </div>
          
          <div class="mt-6">
            <%= f.label :preferred_call_time, "Preferred Call Time", class: "block text-navy text-sm font-semibold mb-3" %>
            <div class="grid md:grid-cols-3 gap-4">
              <label class="flex items-center p-4 border border-gray-300 rounded-sm cursor-pointer hover:border-british-red transition has-[:checked]:border-british-red has-[:checked]:bg-red-50">
                <%= f.radio_button :preferred_call_time, "morning", class: "w-4 h-4 text-british-red mr-3" %>
                <div>
                  <span class="font-semibold text-navy block">Morning</span>
                  <span class="text-xs text-gray-500">9 AM - 12 PM</span>
                </div>
              </label>
              
              <label class="flex items-center p-4 border border-gray-300 rounded-sm cursor-pointer hover:border-british-red transition has-[:checked]:border-british-red has-[:checked]:bg-red-50">
                <%= f.radio_button :preferred_call_time, "afternoon", class: "w-4 h-4 text-british-red mr-3" %>
                <div>
                  <span class="font-semibold text-navy block">Afternoon</span>
                  <span class="text-xs text-gray-500">12 PM - 4 PM</span>
                </div>
              </label>
              
              <label class="flex items-center p-4 border border-gray-300 rounded-sm cursor-pointer hover:border-british-red transition has-[:checked]:border-british-red has-[:checked]:bg-red-50">
                <%= f.radio_button :preferred_call_time, "evening", class: "w-4 h-4 text-british-red mr-3" %>
                <div>
                  <span class="font-semibold text-navy block">Evening</span>
                  <span class="text-xs text-gray-500">4 PM - 7 PM</span>
                </div>
              </label>
            </div>
          </div>
          
          <div class="mt-6">
            <%= f.label :message, "Additional Message (Optional)", class: "block text-navy text-sm font-semibold mb-2" %>
            <%= f.text_area :message, rows: 4, class: "w-full px-4 py-3 border border-gray-300 rounded-sm focus:outline-none focus:border-british-red transition", placeholder: "Any specific questions or information you'd like to share..." %>
          </div>
          
          <div class="mt-8">
            <%= f.submit "Submit Inquiry", class: "w-full bg-british-red text-white py-3 rounded-sm hover:bg-red-700 transition font-semibold tracking-wide cursor-pointer" %>
          </div>
          
          <p class="text-center text-gray-500 text-xs mt-6">
            By submitting this form, you agree to our privacy policy. We'll contact you within 24 hours.
          </p>
        <% end %>
      </div>
    </div>
  </div>
  

</div>