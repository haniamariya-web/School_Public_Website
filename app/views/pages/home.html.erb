        </div>
      </div>
      
      <div class="border-t border-gray-800 mt-12 pt-8 text-center text-gray-500 text-xs tracking-wide">
        <p>&copy; 2026 Britain International School System - Al-Muqeet Campus. All rights reserved.</p>
      </div>
    </div>
  </footer>
</div>