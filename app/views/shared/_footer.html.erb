<footer class="bg-navy text-white pt-16 pb-8 border-t-[6px] border-british-red">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-12">
      
      <!-- Brand & About -->
      <div class="col-span-1 lg:col-span-1">
        <%= link_to root_path, class: "flex items-center space-x-2 mb-6 inline-block" do %>
          <span class="text-3xl font-bold text-british-red font-playfair">BIS</span>
          <br>
          <span class="text-sm font-light tracking-wide leading-tight">Britain International<br>School System</span>
        <% end %>
        <p class="text-gray-400 text-sm font-light leading-relaxed mb-6">
          Nurturing excellence and shaping the future since 1955. Committed to holistic education, character building, and academic brilliance.
        </p>
        
      </div>

      <!-- Quick Links -->
      <div class="col-span-1">
        <h3 class="text-white font-semibold tracking-wide uppercase text-sm mb-6 font-playfair flex items-center">
          <span class="w-4 h-[2px] bg-british-red mr-3"></span>
          Quick Links
        </h3>
        <ul class="space-y-3">
          <li><%= link_to "About Us", about_path, class: "text-gray-400 hover:text-british-red hover:translate-x-1 transition-all duration-300 inline-block text-sm" %></li>
          <li><%= link_to "Our Campuses", campuses_path, class: "text-gray-400 hover:text-british-red hover:translate-x-1 transition-all duration-300 inline-block text-sm" %></li>
          <li><%= link_to "News & Updates", news_index_path, class: "text-gray-400 hover:text-british-red hover:translate-x-1 transition-all duration-300 inline-block text-sm" %></li>
          <li><%= link_to "Photo Gallery", gallery_path, class: "text-gray-400 hover:text-british-red hover:translate-x-1 transition-all duration-300 inline-block text-sm" %></li>
          <li><%= link_to "Admissions", new_inquiry_path, class: "text-gray-400 hover:text-british-red hover:translate-x-1 transition-all duration-300 inline-block text-sm" %></li>
        </ul>
      </div>

      <!-- Programs -->
      <div class="col-span-1">
        <h3 class="text-white font-semibold tracking-wide uppercase text-sm mb-6 font-playfair flex items-center">
          <span class="w-4 h-[2px] bg-british-red mr-3"></span>
          Our Programs
        </h3>
        <ul class="space-y-3">
          <li class="text-gray-400 text-sm">Play Group & Nursery</li>
          <li class="text-gray-400 text-sm">Primary Education</li>
          <li class="text-gray-400 text-sm">Middle School</li>
          <li class="text-gray-400 text-sm">Matriculation</li>
          <li class="text-gray-400 text-sm">Hifz-Ul-Quran</li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="col-span-1">
        <h3 class="text-white font-semibold tracking-wide uppercase text-sm mb-6 font-playfair flex items-center">
          <span class="w-4 h-[2px] bg-british-red mr-3"></span>
          Contact Us
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start text-sm text-gray-400">
            <svg class="w-5 h-5 text-british-red mr-3 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="leading-relaxed">Al-Muqeet Campus<br>Multan, Pakistan</span>
          </li>
          <li class="flex items-center text-sm text-gray-400">
            <svg class="w-5 h-5 text-british-red mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <span>+92 123 4567890</span>
          </li>
          <li class="flex items-center text-sm text-gray-400">
            <svg class="w-5 h-5 text-british-red mr-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <span>info@britainschool.edu.pk</span>
          </li>
        </ul>
        <div class="flex space-x-4 mt-4">
          <!-- Social Icons (Placeholders) -->
          <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-gray-300 hover:bg-british-red hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
          </a>
          <a href="#" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-gray-300 hover:bg-british-red hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
          </a>
         
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-500 text-xs text-center md:text-left">
        &copy; <%= Time.current.year %> Britain International School System. All rights reserved.
      </p>
      <div class="flex space-x-6 text-xs text-gray-500">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
        <%= link_to "Admin Login", admin_root_path, class: "hover:text-british-red transition-colors" %>
      </div>
    </div>
  </div>
</footer>
